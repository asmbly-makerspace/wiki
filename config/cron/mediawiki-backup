# mediawiki-backup — cron.d job for nightly S3 backup with GFS retention
# Uploaded to /tmp/ by Packer; installed by 07-backup-setup.sh.
# Runs nightly at 02:00 CDT = 08:00 UTC
# Edit /etc/sysconfig/mediawiki-backup to configure bucket and retention
SHELL=/bin/bash

0 8 * * * root /opt/mediawiki-ami/backup-with-retention.sh >> /var/log/mediawiki-backup.log 2>&1

