{
  "Rules": [
    {
      "ID": "mediawiki-daily-expire",
      "Filter": { "Prefix": "backups/daily/" },
      "Status": "Enabled",
      "Expiration": { "Days": 5 }
    },
    {
      "ID": "mediawiki-weekly-tier",
      "Filter": { "Prefix": "backups/weekly/" },
      "Status": "Enabled",
      "Transitions": [
        { "Days": 14, "StorageClass": "STANDARD_IA" }
      ],
      "Expiration": { "Days": 57 }
    },
    {
      "ID": "mediawiki-monthly-tier",
      "Filter": { "Prefix": "backups/monthly/" },
      "Status": "Enabled",
      "Transitions": [
        { "Days": 30,  "StorageClass": "STANDARD_IA" },
        { "Days": 90,  "StorageClass": "GLACIER_IR"  }
      ],
      "Expiration": { "Days": 366 }
    },
    {
      "ID": "mediawiki-abort-incomplete-multipart",
      "Filter": { "Prefix": "backups/" },
      "Status": "Enabled",
      "AbortIncompleteMultipartUpload": { "DaysAfterInitiation": 3 }
    },
    {
      "ID": "mediawiki-expire-noncurrent-versions",
      "Filter": { "Prefix": "backups/" },
      "Status": "Enabled",
      "NoncurrentVersionExpiration": { "NoncurrentDays": 30 }
    }
  ]
}

