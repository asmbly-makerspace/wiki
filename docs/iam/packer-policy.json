{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PackerDescribeResources",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeImages",
        "ec2:DescribeImageAttribute",
        "ec2:DescribeRegions",
        "ec2:DescribeVpcs",
        "ec2:DescribeSubnets",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceStatus",
        "ec2:DescribeVolumes",
        "ec2:DescribeSnapshots",
        "ec2:DescribeTags"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": { "aws:RequestedRegion": "us-east-2" }
      }
    },
    {
      "Sid": "PackerCreateKeyPair",
      "Effect": "Allow",
      "Action": "ec2:CreateKeyPair",
      "Resource": "arn:aws:ec2:us-east-2:*:key-pair/*",
      "Condition": {
        "StringEquals": { "aws:RequestTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerDeleteKeyPair",
      "Effect": "Allow",
      "Action": "ec2:DeleteKeyPair",
      "Resource": "arn:aws:ec2:us-east-2:*:key-pair/*",
      "Condition": {
        "StringEquals": { "aws:ResourceTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerCreateSecurityGroup",
      "Effect": "Allow",
      "Action": "ec2:CreateSecurityGroup",
      "Resource": [
        "arn:aws:ec2:us-east-2:*:security-group/*",
        "arn:aws:ec2:us-east-2:*:vpc/*"
      ],
      "Condition": {
        "StringEquals": { "aws:RequestTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerManageSecurityGroup",
      "Effect": "Allow",
      "Action": [
        "ec2:DeleteSecurityGroup",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupEgress"
      ],
      "Resource": "arn:aws:ec2:us-east-2:*:security-group/*",
      "Condition": {
        "StringEquals": { "aws:ResourceTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerRunInstanceNewResources",
      "Effect": "Allow",
      "Action": "ec2:RunInstances",
      "Resource": [
        "arn:aws:ec2:us-east-2:*:instance/*",
        "arn:aws:ec2:us-east-2:*:volume/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/ManagedBy": "packer",
          "ec2:InstanceType": "t4g.medium"
        }
      }
    },
    {
      "Sid": "PackerRunInstanceOwnedRefs",
      "Effect": "Allow",
      "Action": "ec2:RunInstances",
      "Resource": [
        "arn:aws:ec2:us-east-2:*:security-group/*",
        "arn:aws:ec2:us-east-2:*:key-pair/*"
      ],
      "Condition": {
        "StringEquals": { "aws:ResourceTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerRunInstanceExternalRefs",
      "Effect": "Allow",
      "Action": "ec2:RunInstances",
      "Resource": [
        "arn:aws:ec2:us-east-2::image/*",
        "arn:aws:ec2:us-east-2:*:image/*",
        "arn:aws:ec2:us-east-2:*:subnet/*",
        "arn:aws:ec2:us-east-2:*:network-interface/*"
      ],
      "Condition": {
        "StringEquals": { "aws:RequestedRegion": "us-east-2" }
      }
    },
    {
      "Sid": "PackerManageInstance",
      "Effect": "Allow",
      "Action": [
        "ec2:StopInstances",
        "ec2:TerminateInstances",
        "ec2:ModifyInstanceAttribute"
      ],
      "Resource": "arn:aws:ec2:us-east-2:*:instance/*",
      "Condition": {
        "StringEquals": { "aws:ResourceTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerCreateImage",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateImage",
        "ec2:RegisterImage"
      ],
      "Resource": "arn:aws:ec2:us-east-2:*:image/*",
      "Condition": {
        "StringEquals": { "aws:RequestTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerManageImage",
      "Effect": "Allow",
      "Action": [
        "ec2:DeregisterImage",
        "ec2:ModifyImageAttribute"
      ],
      "Resource": "arn:aws:ec2:us-east-2:*:image/*",
      "Condition": {
        "StringEquals": { "aws:ResourceTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerCreateSnapshot",
      "Effect": "Allow",
      "Action": "ec2:CreateSnapshot",
      "Resource": "arn:aws:ec2:us-east-2:*:snapshot/*",
      "Condition": {
        "StringEquals": { "aws:RequestTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerCreateSnapshotFromVolume",
      "Effect": "Allow",
      "Action": "ec2:CreateSnapshot",
      "Resource": "arn:aws:ec2:us-east-2:*:volume/*",
      "Condition": {
        "StringEquals": { "aws:ResourceTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerManageSnapshot",
      "Effect": "Allow",
      "Action": [
        "ec2:DeleteSnapshot",
        "ec2:ModifySnapshotAttribute"
      ],
      "Resource": "arn:aws:ec2:us-east-2:*:snapshot/*",
      "Condition": {
        "StringEquals": { "aws:ResourceTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerCreateVolume",
      "Effect": "Allow",
      "Action": "ec2:CreateVolume",
      "Resource": "arn:aws:ec2:us-east-2:*:volume/*",
      "Condition": {
        "StringEquals": { "aws:RequestTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerManageVolume",
      "Effect": "Allow",
      "Action": [
        "ec2:DeleteVolume",
        "ec2:AttachVolume",
        "ec2:DetachVolume"
      ],
      "Resource": [
        "arn:aws:ec2:us-east-2:*:volume/*",
        "arn:aws:ec2:us-east-2:*:instance/*"
      ],
      "Condition": {
        "StringEquals": { "aws:ResourceTag/ManagedBy": "packer" }
      }
    },
    {
      "Sid": "PackerCreateTags",
      "Effect": "Allow",
      "Action": "ec2:CreateTags",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "us-east-2",
          "ec2:CreateAction": [
            "RunInstances",
            "CreateImage",
            "CreateSnapshot",
            "CreateVolume",
            "CreateKeyPair",
            "CreateSecurityGroup"
          ]
        }
      }
    }
  ]
}
