# packer/test.env.example
# Copy this to packer/test.env (git-ignored) and fill in values for local testing.
# These are sourced by packer/test-local.sh.
#
# Dummy values are fine for testing script logic (download, extract, envsubst).
# Use real values if you need to verify the generated LocalSettings.php is valid.

MW_VERSION=1.43.0
MW_DB_NAME=mediawiki
MW_DB_USER=wiki
PHP_VERSION=8.3

# Secrets — replace with real values or use dummy strings for smoke tests
MW_DB_PASSWORD=test-db-password
MW_SECRET_KEY=$(openssl rand -hex 64 2>/dev/null || echo "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
MW_UPGRADE_KEY=$(openssl rand -hex 16 2>/dev/null || echo "aaaaaaaaaaaaaaaa")
MW_SMTP_PASSWORD=test-smtp-password
MW_DISCOURSE_SECRET=test-discourse-secret

# GitHub PAT — needs read:contents (public repos) or repo scope (private repos).
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_yourTokenHere

